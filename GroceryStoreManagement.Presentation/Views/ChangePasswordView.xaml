<Window x:Class="GroceryStoreManagement.Presentation.Views.ChangePasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu"
        Width="420"
        Height="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Background="White" Padding="28">
        <StackPanel>
            <TextBlock Text="Đổi mật khẩu"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,18" />

            <TextBlock Text="Mật khẩu cũ" />
            <PasswordBox x:Name="OldPasswordInput"
                         PasswordChanged="OldPasswordInput_PasswordChanged"
                         Height="34"
                         Padding="8,6"
                         Margin="4" />

            <TextBlock Text="Mật khẩu mới" />
            <PasswordBox x:Name="NewPasswordInput"
                         PasswordChanged="NewPasswordInput_PasswordChanged"
                         Height="34"
                         Padding="8,6"
                         Margin="4" />

            <TextBlock Text="Xác nhận mật khẩu mới" />
            <PasswordBox x:Name="ConfirmPasswordInput"
                         PasswordChanged="ConfirmPasswordInput_PasswordChanged"
                         Height="34"
                         Padding="8,6"
                         Margin="4" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Đổi mật khẩu" Command="{Binding ChangePasswordCommand}" />
                <Button Content="Đóng" Click="CloseButton_Click" Background="#64748B" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Margin="0,14,0,0" />
        </StackPanel>
    </Border>
</Window>
