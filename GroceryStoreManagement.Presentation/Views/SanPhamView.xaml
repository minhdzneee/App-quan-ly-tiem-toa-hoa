<UserControl x:Class="GroceryStoreManagement.Presentation.Views.SanPhamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" Padding="12" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBox Width="260"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Tìm theo mã, tên hoặc mã vạch" />
                    <ComboBox Width="190"
                              ItemsSource="{Binding DanhMucs}"
                              DisplayMemberPath="TenDanhMuc"
                              SelectedItem="{Binding SelectedDanhMucFilter}"
                              ToolTip="Lọc theo danh mục" />
                    <Button Content="Tìm kiếm" Command="{Binding SearchCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Thêm mới" Command="{Binding NewCommand}" />
                    <Button Content="Lưu" Command="{Binding SaveCommand}" Background="{StaticResource AccentBrush}" />
                    <Button Content="Xóa" Command="{Binding DeleteCommand}" Background="{StaticResource DangerBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding SanPhams}"
                      SelectedItem="{Binding SelectedSanPham}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MaSanPham}" Width="95" />
                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSanPham}" Width="*" />
                    <DataGridTextColumn Header="Danh mục" Binding="{Binding TenDanhMuc}" Width="130" />
                    <DataGridTextColumn Header="ĐVT" Binding="{Binding TenDonVi}" Width="70" />
                    <DataGridTextColumn Header="Giá bán" Binding="{Binding GiaBan, StringFormat={}{0:N0}}" Width="100" />
                    <DataGridTextColumn Header="Tồn" Binding="{Binding SoLuongTon}" Width="60" />
                    <DataGridTextColumn Header="Tối thiểu" Binding="{Binding TonToiThieu}" Width="80" />
                    <DataGridTextColumn Header="Hạn sử dụng" Binding="{Binding HanSuDung, StringFormat={}{0:dd/MM/yyyy}}" Width="110" />
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="95" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Background="White" Padding="16" Margin="12,4,4,4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Thông tin sản phẩm" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <TextBlock Text="Mã sản phẩm" />
                        <TextBox Text="{Binding EditingSanPham.MaSanPham, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Tên sản phẩm" />
                        <TextBox Text="{Binding EditingSanPham.TenSanPham, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Danh mục" />
                        <ComboBox ItemsSource="{Binding DanhMucs}"
                                  DisplayMemberPath="TenDanhMuc"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding EditingSanPham.DanhMucId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Đơn vị tính" />
                        <ComboBox ItemsSource="{Binding DonViTinhs}"
                                  DisplayMemberPath="TenDonVi"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding EditingSanPham.DonViTinhId, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Giá nhập" />
                        <TextBox Text="{Binding EditingSanPham.GiaNhap, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Giá bán" />
                        <TextBox Text="{Binding EditingSanPham.GiaBan, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Số lượng tồn" />
                        <TextBox Text="{Binding EditingSanPham.SoLuongTon, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Tồn tối thiểu" />
                        <TextBox Text="{Binding EditingSanPham.TonToiThieu, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Hạn sử dụng" />
                        <DatePicker SelectedDate="{Binding EditingSanPham.HanSuDung}" Margin="4" />

                        <TextBlock Text="Mã vạch" />
                        <TextBox Text="{Binding EditingSanPham.MaVach, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Trạng thái" />
                        <ComboBox SelectedValue="{Binding EditingSanPham.TrangThai}">
                            <ComboBoxItem Content="DangBan" />
                            <ComboBoxItem Content="NgungBan" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#475569"
                   Margin="4,12,0,0" />
    </Grid>
</UserControl>
