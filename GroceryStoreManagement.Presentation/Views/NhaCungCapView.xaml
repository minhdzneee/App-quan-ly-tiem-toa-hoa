<UserControl x:Class="GroceryStoreManagement.Presentation.Views.NhaCungCapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Thêm mới" Command="{Binding NewCommand}" />
                <Button Content="Lưu" Command="{Binding SaveCommand}" Background="{StaticResource AccentBrush}" />
                <Button Content="Xóa" Command="{Binding DeleteCommand}" Background="{StaticResource DangerBrush}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding NhaCungCaps}"
                      SelectedItem="{Binding SelectedNhaCungCap}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NCC" Binding="{Binding MaNhaCungCap}" Width="120" />
                    <DataGridTextColumn Header="Tên nhà cung cấp" Binding="{Binding TenNhaCungCap}" Width="220" />
                    <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SoDienThoai}" Width="140" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" />
                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Background="White" Padding="16" Margin="12,4,4,4">
                <StackPanel>
                    <TextBlock Text="Thông tin nhà cung cấp" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Mã nhà cung cấp" />
                    <TextBox Text="{Binding EditingNhaCungCap.MaNhaCungCap, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Tên nhà cung cấp" />
                    <TextBox Text="{Binding EditingNhaCungCap.TenNhaCungCap, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Số điện thoại" />
                    <TextBox Text="{Binding EditingNhaCungCap.SoDienThoai, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Email" />
                    <TextBox Text="{Binding EditingNhaCungCap.Email, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Địa chỉ" />
                    <TextBox Text="{Binding EditingNhaCungCap.DiaChi, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="#475569" Margin="4,12,0,0" />
    </Grid>
</UserControl>
