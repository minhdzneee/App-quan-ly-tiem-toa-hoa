<UserControl x:Class="GroceryStoreManagement.Presentation.Views.NhaCungCapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataGrid ItemsSource="{Binding NhaCungCaps}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Mã NCC" Binding="{Binding MaNhaCungCap}" Width="120" />
            <DataGridTextColumn Header="Tên nhà cung cấp" Binding="{Binding TenNhaCungCap}" Width="220" />
            <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SoDienThoai}" Width="140" />
            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" />
            <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*" />
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
