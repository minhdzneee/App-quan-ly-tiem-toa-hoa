<UserControl x:Class="GroceryStoreManagement.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <UniformGrid Columns="5" Margin="0,0,0,18">
            <Border Background="White" Padding="18" Margin="4">
                <StackPanel>
                    <TextBlock Text="Doanh thu hôm nay" Foreground="#64748B" />
                    <TextBlock Text="{Binding Stats.DoanhThuHomNay, StringFormat={}{0:N0} đ}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Background="White" Padding="18" Margin="4">
                <StackPanel>
                    <TextBlock Text="Hóa đơn hôm nay" Foreground="#64748B" />
                    <TextBlock Text="{Binding Stats.TongHoaDonHomNay}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Background="White" Padding="18" Margin="4">
                <StackPanel>
                    <TextBlock Text="Phiếu nhập tháng" Foreground="#64748B" />
                    <TextBlock Text="{Binding Stats.TongPhieuNhapThang}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Background="White" Padding="18" Margin="4">
                <StackPanel>
                    <TextBlock Text="Tồn kho thấp" Foreground="#64748B" />
                    <TextBlock Text="{Binding Stats.SanPhamTonKhoThap}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                </StackPanel>
            </Border>
            <Border Background="White" Padding="18" Margin="4">
                <StackPanel>
                    <TextBlock Text="Sắp hết hạn" Foreground="#64748B" />
                    <TextBlock Text="{Binding Stats.SanPhamSapHetHan}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Background="White" Padding="18">
            <StackPanel>
                <TextBlock Text="Tổng quan nghiệp vụ"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock Text="Dashboard hiển thị nhanh doanh thu, hóa đơn, phiếu nhập và cảnh báo tồn kho để chủ cửa hàng theo dõi vận hành trong ngày."
                           TextWrapping="Wrap"
                           Foreground="#475569" />
                <Button Content="Tải lại" Command="{Binding LoadCommand}" HorizontalAlignment="Left" Margin="0,16,0,0" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
