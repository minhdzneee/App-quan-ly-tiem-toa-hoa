<UserControl x:Class="GroceryStoreManagement.Presentation.Views.BanHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" Padding="12" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBox Width="280"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Nhập mã sản phẩm, tên hoặc quét mã vạch" />
                    <Button Content="Tìm" Command="{Binding SearchProductCommand}" />
                    <TextBlock Text="{Binding SelectedSanPham.TenSanPham}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="12,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Khách hàng" VerticalAlignment="Center" Margin="4,0,8,0" />
                    <ComboBox Width="210"
                              ItemsSource="{Binding KhachHangs}"
                              DisplayMemberPath="HoTen"
                              SelectedItem="{Binding SelectedKhachHang}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="16" Margin="0,4,12,4">
                <StackPanel>
                    <TextBlock Text="Thêm vào hóa đơn" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Số lượng mua" />
                    <TextBox Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Thêm sản phẩm" Command="{Binding AddToInvoiceCommand}" Background="{StaticResource AccentBrush}" />

                    <TextBlock Text="Tổng tiền" Margin="0,28,0,4" Foreground="#64748B" />
                    <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}" FontSize="22" FontWeight="Bold" />

                    <TextBlock Text="Giảm giá" Margin="0,16,0,4" />
                    <TextBox Text="{Binding GiamGia, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Thành tiền" Margin="0,16,0,4" Foreground="#64748B" />
                    <TextBlock Text="{Binding ThanhTien, StringFormat={}{0:N0} đ}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />

                    <Button Content="Thanh toán" Command="{Binding CheckoutCommand}" Margin="4,24,4,4" />
                    <Button Content="Hủy hóa đơn" Command="{Binding ClearCommand}" Background="{StaticResource DangerBrush}" />
                </StackPanel>
            </Border>

            <DataGrid Grid.Column="1" ItemsSource="{Binding InvoiceItems}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MaSanPham}" Width="110" />
                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSanPham}" Width="*" />
                    <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong}" Width="90" />
                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat={}{0:N0}}" Width="110" />
                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="120" />
                    <DataGridTemplateColumn Header="" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Xóa"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="{StaticResource DangerBrush}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#475569"
                   Margin="4,12,0,0" />
    </Grid>
</UserControl>
