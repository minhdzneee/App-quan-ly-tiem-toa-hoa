<UserControl x:Class="GroceryStoreManagement.Presentation.Views.BaoCaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Từ ngày" VerticalAlignment="Center" Margin="4,0,8,0" />
                <DatePicker SelectedDate="{Binding FromDate}" Width="150" Margin="4" />
                <TextBlock Text="Đến ngày" VerticalAlignment="Center" Margin="12,0,8,0" />
                <DatePicker SelectedDate="{Binding ToDate}" Width="150" Margin="4" />
                <Button Content="Tải báo cáo" Command="{Binding LoadCommand}" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Tổng quan">
                <UniformGrid Columns="5" Margin="8">
                    <Border Background="White" Padding="16" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Doanh thu hôm nay" Foreground="#64748B" />
                            <TextBlock Text="{Binding Stats.DoanhThuHomNay, StringFormat={}{0:N0} đ}" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" Padding="16" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Hóa đơn hôm nay" Foreground="#64748B" />
                            <TextBlock Text="{Binding Stats.TongHoaDonHomNay}" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" Padding="16" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Phiếu nhập tháng" Foreground="#64748B" />
                            <TextBlock Text="{Binding Stats.TongPhieuNhapThang}" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" Padding="16" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Tồn kho thấp" Foreground="#64748B" />
                            <TextBlock Text="{Binding Stats.SanPhamTonKhoThap}" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" Padding="16" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Sắp hết hạn" Foreground="#64748B" />
                            <TextBlock Text="{Binding Stats.SanPhamSapHetHan}" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </TabItem>

            <TabItem Header="Bán chạy">
                <DataGrid ItemsSource="{Binding TopSanPhamBanChay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaSanPham}" Width="120" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSanPham}" Width="*" />
                        <DataGridTextColumn Header="Số lượng bán" Binding="{Binding SoLuongBan}" Width="130" />
                        <DataGridTextColumn Header="Doanh thu" Binding="{Binding DoanhThu, StringFormat={}{0:N0}}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Tồn kho thấp">
                <DataGrid ItemsSource="{Binding SanPhamTonKhoThap}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaSanPham}" Width="120" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSanPham}" Width="*" />
                        <DataGridTextColumn Header="Tồn" Binding="{Binding SoLuongTon}" Width="100" />
                        <DataGridTextColumn Header="Tồn tối thiểu" Binding="{Binding TonToiThieu}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Sắp hết hạn">
                <DataGrid ItemsSource="{Binding SanPhamSapHetHan}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã" Binding="{Binding MaSanPham}" Width="120" />
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSanPham}" Width="*" />
                        <DataGridTextColumn Header="Hạn sử dụng" Binding="{Binding HanSuDung, StringFormat={}{0:dd/MM/yyyy}}" Width="140" />
                        <DataGridTextColumn Header="Tồn" Binding="{Binding SoLuongTon}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#475569"
                   Margin="4,12,0,0" />
    </Grid>
</UserControl>
