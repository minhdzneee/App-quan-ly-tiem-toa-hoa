<UserControl x:Class="GroceryStoreManagement.Presentation.Views.DanhMucView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Thêm mới" Command="{Binding NewCommand}" />
                <Button Content="Lưu" Command="{Binding SaveCommand}" Background="{StaticResource AccentBrush}" />
                <Button Content="Xóa" Command="{Binding DeleteCommand}" Background="{StaticResource DangerBrush}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding DanhMucs}"
                      SelectedItem="{Binding SelectedDanhMuc}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã danh mục" Binding="{Binding MaDanhMuc}" Width="160" />
                    <DataGridTextColumn Header="Tên danh mục" Binding="{Binding TenDanhMuc}" Width="220" />
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding MoTa}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Background="White" Padding="16" Margin="12,4,4,4">
                <StackPanel>
                    <TextBlock Text="Thông tin danh mục" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Mã danh mục" />
                    <TextBox Text="{Binding EditingDanhMuc.MaDanhMuc, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Tên danh mục" />
                    <TextBox Text="{Binding EditingDanhMuc.TenDanhMuc, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Mô tả" />
                    <TextBox Text="{Binding EditingDanhMuc.MoTa, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="90" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="#475569" Margin="4,12,0,0" />
    </Grid>
</UserControl>
