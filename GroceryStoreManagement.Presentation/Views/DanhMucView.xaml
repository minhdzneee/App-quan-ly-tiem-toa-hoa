<UserControl x:Class="GroceryStoreManagement.Presentation.Views.DanhMucView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataGrid ItemsSource="{Binding DanhMucs}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Mã danh mục" Binding="{Binding MaDanhMuc}" Width="160" />
            <DataGridTextColumn Header="Tên danh mục" Binding="{Binding TenDanhMuc}" Width="220" />
            <DataGridTextColumn Header="Mô tả" Binding="{Binding MoTa}" Width="*" />
        </DataGrid.Columns>
    </DataGrid>
</UserControl>
