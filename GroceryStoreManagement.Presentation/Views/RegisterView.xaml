<Window x:Class="GroceryStoreManagement.Presentation.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo tài khoản"
        Width="460"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Background="White" Padding="28">
        <StackPanel>
            <TextBlock Text="Tạo tài khoản"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,18" />

            <TextBlock Text="Tên đăng nhập" />
            <TextBox Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Họ tên nhân viên" />
            <TextBox Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Vai trò" />
            <ComboBox ItemsSource="{Binding VaiTros}"
                      DisplayMemberPath="TenVaiTro"
                      SelectedItem="{Binding SelectedVaiTro}" />

            <TextBlock Text="Mật khẩu" />
            <PasswordBox x:Name="PasswordInput"
                         PasswordChanged="PasswordInput_PasswordChanged"
                         Height="34"
                         Padding="8,6"
                         Margin="4" />

            <TextBlock Text="Xác nhận mật khẩu" />
            <PasswordBox x:Name="ConfirmPasswordInput"
                         PasswordChanged="ConfirmPasswordInput_PasswordChanged"
                         Height="34"
                         Padding="8,6"
                         Margin="4" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Tạo tài khoản" Command="{Binding RegisterCommand}" />
                <Button Content="Đóng" Click="CloseButton_Click" Background="#64748B" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Margin="0,14,0,0" />
        </StackPanel>
    </Border>
</Window>
