<Window x:Class="GroceryStoreManagement.Presentation.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - Quản lý hàng tạp hóa"
        Width="900"
        Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel VerticalAlignment="Center" Margin="56">
                <TextBlock Text="HỆ THỐNG"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="QUẢN LÝ HÀNG TẠP HÓA"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,8,0,16" />
                <TextBlock Text="Quản lý sản phẩm, nhập hàng, bán hàng, tồn kho và báo cáo doanh thu trong một ứng dụng WPF theo mô hình MVVM."
                           Foreground="#E5F4F8"
                           FontSize="16"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="54">
                <TextBlock Text="Đăng nhập"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,24" />

                <TextBlock Text="Tên đăng nhập" Foreground="{StaticResource TextBrush}" />
                <TextBox Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         Margin="0,6,0,14" />

                <TextBlock Text="Mật khẩu" Foreground="{StaticResource TextBrush}" />
                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="PasswordInput_PasswordChanged"
                             Height="38"
                             Padding="8,6"
                             Margin="0,6,0,18" />

                <Button Content="Đăng nhập"
                        Command="{Binding LoginCommand}"
                        Height="42"
                        Margin="0,0,0,12" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap" />

                <TextBlock Text="Tài khoản mẫu: admin / 123456"
                           Foreground="#6B7280"
                           Margin="0,28,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
