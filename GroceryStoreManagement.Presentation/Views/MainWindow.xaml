<Window x:Class="GroceryStoreManagement.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý hàng tạp hóa"
        Width="1280"
        Height="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#12343B">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18,24,18,16">
                    <TextBlock Text="TẠP HÓA"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="Quản lý bán hàng"
                               Foreground="#B7DDE7"
                               Margin="0,4,0,18" />

                    <Button Content="Dashboard"
                            Command="{Binding ShowDashboardCommand}"
                            Visibility="{Binding CanViewDashboard, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Sản phẩm"
                            Command="{Binding ShowSanPhamCommand}"
                            Visibility="{Binding CanViewSanPham, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Danh mục"
                            Command="{Binding ShowDanhMucCommand}"
                            Visibility="{Binding CanViewDanhMuc, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Đơn vị tính"
                            Command="{Binding ShowDonViTinhCommand}"
                            Visibility="{Binding CanViewDonViTinh, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Nhà cung cấp"
                            Command="{Binding ShowNhaCungCapCommand}"
                            Visibility="{Binding CanViewNhaCungCap, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Nhập hàng"
                            Command="{Binding ShowNhapHangCommand}"
                            Visibility="{Binding CanViewNhapHang, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Bán hàng"
                            Command="{Binding ShowBanHangCommand}"
                            Visibility="{Binding CanViewBanHang, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Khách hàng"
                            Command="{Binding ShowKhachHangCommand}"
                            Visibility="{Binding CanViewKhachHang, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Kiểm kê"
                            Command="{Binding ShowKiemKeCommand}"
                            Visibility="{Binding CanViewKiemKe, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Báo cáo"
                            Command="{Binding ShowBaoCaoCommand}"
                            Visibility="{Binding CanViewBaoCao, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="18,16,18,24">
                    <TextBlock Text="{Binding UserDisplayName}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding RoleDisplayName}"
                               Foreground="#B7DDE7"
                               TextWrapping="Wrap" />
                    <Button Content="Đổi mật khẩu"
                            Command="{Binding ChangePasswordCommand}"
                            Background="#64748B"
                            Margin="0,14,0,0" />
                    <Button Content="Đăng xuất"
                            Command="{Binding LogoutCommand}"
                            Background="{StaticResource DangerBrush}"
                            Margin="0,6,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding PageTitle}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,18" />

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />
        </Grid>
    </Grid>
</Window>
