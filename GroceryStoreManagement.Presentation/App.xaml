<Application x:Class="GroceryStoreManagement.Presentation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:GroceryStoreManagement.Presentation.Views"
             xmlns:vm="clr-namespace:GroceryStoreManagement.Presentation.ViewModels"
             StartupUri="Views/LoginView.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#176B87" />
        <SolidColorBrush x:Key="AccentBrush" Color="#86B049" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C2410C" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F6F7F2" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2933" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SanPhamViewModel}">
            <views:SanPhamView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DanhMucViewModel}">
            <views:DanhMucView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DonViTinhViewModel}">
            <views:DonViTinhView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NhaCungCapViewModel}">
            <views:NhaCungCapView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NhapHangViewModel}">
            <views:NhapHangView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BanHangViewModel}">
            <views:BanHangView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KhachHangViewModel}">
            <views:KhachHangView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KiemKeViewModel}">
            <views:KiemKeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BaoCaoViewModel}">
            <views:BaoCaoView />
        </DataTemplate>
    </Application.Resources>
</Application>
